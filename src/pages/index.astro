---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const url = (path: string) => `${base}${path.replace(/^\//, '')}`;
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = posts[0];
const categories = [
	{ name: 'AI 도구 사용법', desc: 'ChatGPT, Claude, 이미지 생성, 생산성 도구 실전 활용' },
	{ name: '업무 자동화', desc: '반복 업무를 줄이는 워크플로우와 자동화 설계' },
	{ name: '소상공인 AI', desc: '1인 사업자와 매장을 위한 매출/마케팅 자동화' },
	{ name: '블로그 자동화', desc: 'Markdown, GitHub Pages, SEO, 애드센스 운영' },
];
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-copy">
					<p class="badge">⚡ AI · 자동화 · 수익형 콘텐츠</p>
					<h1>AI로 일하고, 자동화로 쌓는 블로그.</h1>
					<p class="lead">{SITE_DESCRIPTION}. 복잡한 AI 정보를 실제 사업과 콘텐츠 운영에 바로 쓰는 방법으로 정리합니다.</p>
					<div class="hero-actions">
						<a class="primary" href={url('/blog')}>최신 글 보기</a>
						<a class="secondary" href="https://github.com/Smartfork-kim/ai-auto-blog" target="_blank">GitHub 저장소</a>
					</div>
				</div>
				<aside class="hero-panel card">
					<span class="panel-label">Today’s system</span>
					<h2>Markdown → GitHub → Pages</h2>
					<p>글 파일을 올리면 GitHub Actions가 자동으로 빌드하고 배포합니다.</p>
					<div class="pipeline">
						<span>AI Draft</span><span>Review</span><span>Publish</span>
					</div>
				</aside>
			</section>

			<section class="section-head">
				<p class="badge">Categories</p>
				<h2>카테고리 구조</h2>
				<p>애드센스 승인과 검색 유입을 고려해서 정보성 콘텐츠 중심으로 설계했습니다.</p>
			</section>
			<section class="category-grid">
				{categories.map((category) => (
					<article class="category-card card">
						<h3>{category.name}</h3>
						<p>{category.desc}</p>
					</article>
				))}
			</section>

			<section class="latest card">
				<div>
					<p class="badge">Latest post</p>
					<h2>최근 글</h2>
				</div>
				{featured && (
					<a class="featured-link" href={url(`/blog/${featured.id}/`)}>
						<span>{featured.data.category}</span>
						<h3>{featured.data.title}</h3>
						<p>{featured.data.description}</p>
						<small><FormattedDate date={featured.data.pubDate} /></small>
					</a>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
		gap: 2rem;
		align-items: center;
		padding: 4rem 0 5rem;
	}
	.hero-copy h1 {
		max-width: 820px;
		margin-top: 1rem;
	}
	.lead {
		max-width: 680px;
		font-size: clamp(1.05rem, 2vw, 1.35rem);
		color: rgb(var(--gray));
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.5rem;
	}
	.primary,
	.secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.15rem;
		border-radius: 999px;
		font-weight: 900;
		text-decoration: none;
	}
	.primary {
		background: linear-gradient(135deg, rgb(var(--accent)), rgb(var(--accent-2)));
		color: white;
		box-shadow: 0 20px 42px rgba(var(--accent), 0.26);
	}
	.secondary {
		border: 1px solid rgb(var(--border));
		background: rgba(255,255,255,0.72);
		color: rgb(var(--black));
	}
	.hero-panel {
		position: relative;
		padding: 2rem;
		overflow: hidden;
	}
	.hero-panel::before {
		content: "";
		position: absolute;
		inset: -30% -20% auto auto;
		width: 220px;
		height: 220px;
		border-radius: 999px;
		background: rgba(var(--accent-2), 0.22);
		filter: blur(2px);
	}
	.panel-label {
		position: relative;
		color: rgb(var(--accent));
		font-size: 0.85rem;
		font-weight: 900;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.hero-panel h2 {
		position: relative;
		font-size: clamp(2rem, 4vw, 3.1rem);
		margin-top: 1rem;
	}
	.hero-panel p {
		position: relative;
		color: rgb(var(--gray));
	}
	.pipeline {
		position: relative;
		display: grid;
		gap: 0.65rem;
		margin-top: 1.25rem;
	}
	.pipeline span {
		padding: 0.8rem 0.9rem;
		border-radius: 16px;
		background: rgba(15, 23, 42, 0.92);
		color: white;
		font-weight: 800;
	}
	.section-head {
		max-width: 760px;
		margin-bottom: 1.25rem;
	}
	.section-head p:last-child {
		color: rgb(var(--gray));
	}
	.category-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.category-card {
		padding: 1.35rem;
		transition: transform 0.18s ease, box-shadow 0.18s ease;
	}
	.category-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow);
	}
	.category-card h3 {
		font-size: 1.25rem;
	}
	.category-card p {
		color: rgb(var(--gray));
		font-size: 0.96rem;
	}
	.latest {
		display: grid;
		grid-template-columns: 0.8fr 1.2fr;
		gap: 1rem;
		align-items: center;
		padding: 1.5rem;
	}
	.featured-link {
		display: block;
		padding: 1.4rem;
		border-radius: 22px;
		background: linear-gradient(135deg, rgba(var(--accent), 0.1), rgba(var(--accent-2), 0.1));
		text-decoration: none;
	}
	.featured-link span {
		color: rgb(var(--accent));
		font-size: 0.9rem;
		font-weight: 900;
	}
	.featured-link h3 {
		margin-top: 0.45rem;
	}
	.featured-link p {
		color: rgb(var(--gray));
	}
	.featured-link small {
		color: rgb(var(--gray));
	}
	@media (max-width: 900px) {
		.hero,
		.latest {
			grid-template-columns: 1fr;
		}
		.category-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 560px) {
		.hero {
			padding-top: 2rem;
		}
		.category-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
