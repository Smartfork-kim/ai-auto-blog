---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

 type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags = [] } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="post-hero">
					<div class="post-meta">
						<span class="badge">{category}</span>
						<small><FormattedDate date={pubDate} /></small>
					</div>
					<h1>{title}</h1>
					<p>{description}</p>
					{tags.length > 0 && (
						<div class="tags">
							{tags.map((tag) => <span>#{tag}</span>)}
						</div>
					)}
					{updatedDate && <small class="updated">업데이트: <FormattedDate date={updatedDate} /></small>}
				</header>
				{heroImage && (
					<div class="hero-image">
						<Image width={1120} height={560} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose card">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: min(1120px, calc(100% - 2rem));
	}
	.post-hero {
		max-width: 880px;
		margin: 0 auto;
		padding: 3rem 0 2rem;
		text-align: center;
	}
	.post-meta {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1.25rem;
		color: rgb(var(--gray));
	}
	.post-hero h1 {
		font-size: clamp(2.4rem, 6vw, 4.8rem);
	}
	.post-hero p {
		max-width: 680px;
		margin: 0 auto 1.25rem;
		color: rgb(var(--gray));
		font-size: 1.18rem;
	}
	.tags {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 1rem;
	}
	.tags span {
		padding: 0.38rem 0.62rem;
		border-radius: 999px;
		background: rgba(var(--accent), 0.08);
		color: rgb(var(--accent));
		font-size: 0.86rem;
		font-weight: 800;
	}
	.updated {
		display: block;
		margin-top: 1rem;
		color: rgb(var(--gray));
	}
	.hero-image {
		margin-bottom: 1.5rem;
	}
	.hero-image img {
		display: block;
		width: 100%;
		border-radius: 30px;
		box-shadow: var(--shadow);
	}
	.prose {
		width: min(780px, 100%);
		margin: 0 auto;
		padding: clamp(1.25rem, 4vw, 3rem);
	}
</style>
