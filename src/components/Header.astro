---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const url = (path: string) => `${base}${path.replace(/^\//, '')}`;
---

<header>
	<nav>
		<a class="brand" href={base} aria-label={`${SITE_TITLE} 홈`}>
			<span class="brand-mark">A</span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href={base}>Home</HeaderLink>
			<HeaderLink href={url('/blog')}>Blog</HeaderLink>
			<HeaderLink href={url('/about')}>About</HeaderLink>
		</div>
		<a class="repo-link" href="https://github.com/Smartfork-kim/ai-auto-blog" target="_blank">GitHub</a>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		padding: 0.75rem 1rem;
		background: rgba(248, 250, 252, 0.72);
		border-bottom: 1px solid rgba(var(--border), 0.74);
		backdrop-filter: blur(18px);
	}
	nav {
		width: min(1120px, 100%);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.brand,
	.repo-link,
	nav a {
		text-decoration: none;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		color: rgb(var(--black));
		font-size: 1rem;
		font-weight: 900;
		letter-spacing: -0.03em;
	}
	.brand-mark {
		display: grid;
		place-items: center;
		width: 2rem;
		height: 2rem;
		border-radius: 0.8rem;
		background: linear-gradient(135deg, rgb(var(--accent)), rgb(var(--accent-2)));
		color: white;
		box-shadow: 0 14px 32px rgba(var(--accent), 0.24);
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.35rem;
		border: 1px solid rgba(var(--border), 0.8);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.72);
	}
	.internal-links a {
		padding: 0.45rem 0.8rem;
		border-radius: 999px;
		color: rgb(var(--gray));
		font-size: 0.92rem;
		font-weight: 800;
	}
	.repo-link {
		padding: 0.65rem 0.95rem;
		border-radius: 999px;
		background: rgb(var(--black));
		color: white;
		font-size: 0.9rem;
		font-weight: 800;
		box-shadow: 0 12px 26px rgba(15, 23, 42, 0.16);
	}
	@media (max-width: 720px) {
		header {
			padding: 0.55rem 0.65rem;
		}
		.brand span:last-child {
			display: none;
		}
		.repo-link {
			display: none;
		}
		.internal-links {
			margin-left: auto;
		}
	}
</style>
