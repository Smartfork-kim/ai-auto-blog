---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT;

const { title, description, image = FallbackImage } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
<link rel="icon" href={`${base}favicon.ico`} />
<link rel="sitemap" href={`${base}sitemap-index.xml`} />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL(`${base}rss.xml`.replace(/^\//, ''), Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<style is:inline>
	:root{--accent:79,70,229;--accent-2:14,165,233;--accent-3:16,185,129;--black:15,23,42;--gray:100,116,139;--gray-light:226,232,240;--gray-dark:30,41,59;--surface:255,255,255;--border:226,232,240;--shadow:0 24px 80px rgba(15,23,42,.10);--shadow-soft:0 14px 40px rgba(15,23,42,.08);--radius:28px}
	*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;padding:0;background:radial-gradient(circle at top left,rgba(var(--accent-2),.18),transparent 34rem),radial-gradient(circle at top right,rgba(var(--accent),.16),transparent 32rem),linear-gradient(180deg,#f8fbff 0%,#fff 42%,#f8fafc 100%);color:rgb(var(--gray-dark));font-family:var(--font-atkinson),system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;font-size:18px;line-height:1.75}main{width:min(1120px,calc(100% - 2rem));margin:auto;padding:3.5rem 0}h1,h2,h3,h4,h5,h6{margin:0 0 .75rem;color:rgb(var(--black));line-height:1.12;letter-spacing:-.04em}h1{font-size:clamp(2.8rem,8vw,5.6rem)}h2{font-size:clamp(2rem,4vw,3.25rem)}a{color:rgb(var(--accent))}.badge{display:inline-flex;align-items:center;gap:.45rem;padding:.45rem .75rem;border:1px solid rgba(var(--accent),.16);border-radius:999px;background:rgba(255,255,255,.72);box-shadow:0 8px 28px rgba(15,23,42,.06);color:rgb(var(--accent));font-size:.88rem;font-weight:800}.card{border:1px solid rgba(var(--border),.9);border-radius:var(--radius);background:rgba(var(--surface),.82);box-shadow:var(--shadow-soft);backdrop-filter:blur(18px)}
	@media(max-width:720px){body{font-size:16px}main{width:min(100% - 1.25rem,1120px);padding:2rem 0}}
</style>
{adsenseClient && (
	<script
		async
		src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
		crossorigin="anonymous"
	></script>
)}

<Font cssVariable="--font-atkinson" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />
